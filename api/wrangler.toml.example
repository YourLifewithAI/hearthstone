# Copy this file to wrangler.toml, then fill in the placeholders.
# See BUILD.md for the step-by-step.

name = "hearthstone-api"              # Change to anything unique to you
main = "src/index.ts"
compatibility_date = "2025-04-01"
compatibility_flags = ["nodejs_compat"]
workers_dev = true

[vars]
# The URL of your deployed PWA. Used for CORS.
# After you deploy Pages, update this and redeploy the Worker.
PAGES_ORIGIN = "https://YOUR-PWA-URL.pages.dev"

[[kv_namespaces]]
binding = "HEARTHSTONE_KV"
# Create with: npx wrangler kv namespace create HEARTHSTONE_KV
# Then paste the returned ID below.
id = "PASTE_KV_NAMESPACE_ID_HERE"

# ─── Secrets (set via `wrangler secret put`) ───────────────────────────────────────────────────────
# Required:
#   HEARTHSTONE_API_KEY       — bearer token the PWA uses to talk to this Worker
#
# At least ONE provider credential:
#   OPENROUTER_API_KEY        — OpenRouter gateway (recommended default, 300+ models)
#   ANTHROPIC_API_KEY         — direct Anthropic Messages API (if you prefer no gateway)
#
# Optional:
#   LOCAL_RELAY_URL           — https URL of your own relay server (e.g. via Cloudflare Tunnel)
#   LOCAL_RELAY_TOKEN         — bearer token for your relay (if it requires auth)
#
# Example:
#   wrangler secret put HEARTHSTONE_API_KEY
#   wrangler secret put OPENROUTER_API_KEY
#   wrangler secret put ANTHROPIC_API_KEY        # optional
#   wrangler secret put LOCAL_RELAY_URL          # optional
#   wrangler secret put LOCAL_RELAY_TOKEN        # optional
